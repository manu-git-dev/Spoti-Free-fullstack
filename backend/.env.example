# Modele de configuration. Copier en `.env` et remplir avec les vraies valeurs.
# Le `.env` reel n'est JAMAIS commite (voir .gitignore).

# --- Base de donnees ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=spotifree
DB_PORT=8889          # 8889 = MAMP par defaut (et non 3306)

# --- Serveur ---
PORT=3000
# En production, mettre exactement : production
# Cela active `trust proxy` dans server.js (indispensable derriere un reverse proxy,
# sinon le rate limiter voit l'IP du proxy et bloque tous les visiteurs d'un coup).
NODE_ENV=development

# Origine autorisee par CORS = l'URL du frontend deploye (ex: https://spotifree.fr).
# localhost:5173 reste autorise en plus, pour le dev.
FRONTEND_URL=http://localhost:5173

# Coupe les limites anti-abus (brute-force, spam du formulaire de contact) pour permettre a la
# suite de tests de creer plusieurs comptes sans se faire bloquer. Mettre a 1 en local si tu
# lances `cd tests && npm test`.
# SANS EFFET si NODE_ENV=production : les protections restent actives quoi qu'il arrive.
RATE_LIMIT_DISABLED=0

# --- Authentification ---
# Cle qui SIGNE tous les tokens JWT. Si elle fuite ou se devine, n'importe qui peut forger
# un token admin. Generer une valeur aleatoire d'au moins 32 caracteres :
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# La cle de production doit etre DIFFERENTE de celle de developpement.
JWT_SECRET=

# --- Envoi des mails du formulaire de contact (nodemailer / Gmail) ---
# MAIL_PASS n'est pas le mot de passe du compte Google mais un "mot de passe d'application"
# (a generer depuis le compte Google, avec la validation en 2 etapes activee).
MAIL_USER=
MAIL_PASS=
MAIL_TO=
